# Server Configuration
PORT=3001
CORS_ORIGIN=https://your-frontend-url.example.com
NODE_ENV=production

# PocketBase
POCKETBASE_URL=https://your-pocketbase-url.up.railway.app
PB_SUPERUSER_EMAIL=admin@example.com
PB_SUPERUSER_PASSWORD=your-secure-password

# GeminiGen AI Integration
INTEGRATED_AI_API_URL=https://api.geminigen.ai/uapi/v1
INTEGRATED_AI_API_KEY=your-geminigen-api-key
WEBSITE_ID=your-website-id
WEBSITE_DOMAIN=your-frontend-url.example.com
PROXY_ENTRANCE_ID=

# GeminiGen Webhook Signature Verification (optional)
GEMINIGEN_WEBHOOK_PUBLIC_KEY_PATH=

# Stripe (for credit purchases)
STRIPE_SECRET_KEY=sk_live_your-stripe-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# Cashfree (Indian payment gateway, alternative to Stripe)
# Get keys from https://merchant.cashfree.com/merchants/pg/developers/api-keys
# CASHFREE_ENV: "sandbox" or "production"
CASHFREE_ENV=sandbox
CASHFREE_APP_ID=
CASHFREE_SECRET_KEY=
# Public webhook URL Cashfree should call (e.g. https://api.your-domain.com/webhooks/cashfree)
CASHFREE_WEBHOOK_URL=

# Cloudflare Turnstile (anti-bot captcha for signup + login)
# Get your keys at https://dash.cloudflare.com/?to=/:account/turnstile
# If left empty, captcha verification is skipped (dev only).
TURNSTILE_SECRET_KEY=

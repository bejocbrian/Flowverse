# Server Configuration
PORT=3001
CORS_ORIGIN=https://your-frontend-url.example.com
NODE_ENV=production

# PocketBase
POCKETBASE_URL=https://your-pocketbase-url.up.railway.app
PB_SUPERUSER_EMAIL=admin@example.com
PB_SUPERUSER_PASSWORD=your-secure-password

# GeminiGen AI Integration
INTEGRATED_AI_API_URL=https://api.geminigen.ai/uapi/v1
INTEGRATED_AI_API_KEY=your-geminigen-api-key
WEBSITE_ID=your-website-id
WEBSITE_DOMAIN=your-frontend-url.example.com
PROXY_ENTRANCE_ID=

# GeminiGen Webhook Signature Verification (optional)
GEMINIGEN_WEBHOOK_PUBLIC_KEY_PATH=

# Stripe (for credit purchases)
STRIPE_SECRET_KEY=sk_live_your-stripe-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# Cashfree (Indian payment gateway, alternative to Stripe)
# Get keys from https://merchant.cashfree.com/merchants/pg/developers/api-keys
# CASHFREE_ENV: "sandbox" or "production"
CASHFREE_ENV=sandbox
CASHFREE_APP_ID=
CASHFREE_SECRET_KEY=
# Public webhook URL Cashfree should call (e.g. https://api.your-domain.com/webhooks/cashfree)
CASHFREE_WEBHOOK_URL=

# Paytm (Indian payment gateway, coexists with Cashfree/Stripe)
# Get credentials from the Paytm dashboard: https://dashboard.paytmpayments.com/
# PAYTM_ENV: "staging" or "production"
PAYTM_ENV=staging
# Merchant ID (MID) - staging MID is available in the Paytm dashboard
PAYTM_MID=
# Merchant Key - used to sign/verify all requests. KEEP SECRET.
PAYTM_MERCHANT_KEY=
# Website name configured at Paytm. Staging is usually "WEBSTAGING";
# production is usually "DEFAULT" (or your configured site name).
PAYTM_WEBSITE=
# Optional. Public URL Paytm posts the payment result to. If set, the user is
# returned here (?order_id=...) after checkout; otherwise we redirect back to
# the wallet success page with ?paytm_order_id=...
# Example: https://api.your-domain.com/webhooks/paytm
PAYTM_CALLBACK_URL=

# Cloudflare Turnstile (anti-bot captcha for signup + login)
# Get your keys at https://dash.cloudflare.com/?to=/:account/turnstile
# If left empty, captcha verification is skipped (dev only).
TURNSTILE_SECRET_KEY=

# Anti-abuse limits.
# These are configurable live from the admin Settings page ("Abuse Controls"
# tab); the values below are only the FALLBACK DEFAULTS used when the setting
# is missing in the DB or PocketBase is briefly unreachable.
#
# Rolling 24h generation cap per user (admin keys: free_daily_generation_cap,
# paid_daily_generation_cap). Each generation hits the paid provider; this
# bounds the submit/fail/refund loop that a credit balance alone does not.
# A user counts as "paid" once they have at least one credit purchase.
FREE_DAILY_GENERATION_CAP=50
PAID_DAILY_GENERATION_CAP=500

# Per-user generation burst rate for FREE users only (admin key:
# free_generation_rate_max). Paid users bypass this. The window length is env
# only (express-rate-limit fixes it at startup); the max is admin-editable.
FREE_GENERATION_RATE_MAX=5
FREE_GENERATION_RATE_WINDOW_MS=60000

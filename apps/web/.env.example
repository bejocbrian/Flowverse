# API Backend URL (required for production)
# In development, this uses the Vite proxy - leave unset.
VITE_API_URL=https://your-api-url.example.com

# PocketBase URL (required for production)
# In development, this uses the Vite proxy - leave unset.
VITE_POCKETBASE_URL=https://your-pocketbase-url.example.com

# Cloudflare Turnstile site key (PUBLIC - safe to expose).
# Get yours at https://dash.cloudflare.com/?to=/:account/turnstile
# If empty, the captcha widget is hidden and the API skips verification too.
VITE_TURNSTILE_SITE_KEY=

# Cashfree SDK mode override (OPTIONAL).
# Normally the frontend gets the mode from the API (/settings/public ->
# cashfree_mode), which mirrors the API's CASHFREE_ENV. Only set this if you
# want to force the client SDK into "sandbox" or "production" regardless.
VITE_CASHFREE_ENV=
